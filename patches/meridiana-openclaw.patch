+import { createHash } from "crypto"
 import type { Context } from "hono"
 import type { AgentAdapter } from "../adapter"
 import { normalizeContent } from "../messages"
 import { iterateWithTimeout } from "../iterateWithTimeout"
 
+// ─── Billing Header (Layer 1) ─────────────────────────────────────────────────
+// Anthropic checks the system prompt for this identifier string.
+// Without it, OAuth requests are silently routed to Extra Usage billing.
+const CC_VERSION = "2.1.97"
+const BILLING_HASH_SALT = "59cf53e54c78"
+const BILLING_HASH_INDICES = [4, 7, 20]
+
+function extractFirstUserText(body: any): string {
+  if (!body?.messages) return ""
+  for (const msg of body.messages) {
+    if (msg.role !== "user") continue
+    if (typeof msg.content === "string") return msg.content
+    if (Array.isArray(msg.content)) {
+      for (const block of msg.content) {
+        if (block.type === "text" && block.text) return block.text as string
+      }
+    }
+  }
+  return ""
+}
+
+function computeBillingHeader(firstUserText: string): string {
+  const chars = BILLING_HASH_INDICES.map(i => firstUserText[i] ?? "0").join("")
+  const input = `${BILLING_HASH_SALT}${chars}${CC_VERSION}`
+  const fp = createHash("sha256").update(input).digest("hex").slice(0, 3)
+  return `x-anthropic-billing-header: cc_version=${CC_VERSION}.${fp}; cc_entrypoint=cli; cch=00000;`
+}
