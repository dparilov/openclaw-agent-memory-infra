+// ─── SDK Built-in Tool Mapping ─────────────────────────────────────────────────
+// Maps Claude Code SDK built-in tool names to OpenClaw MCP equivalents.
+// In passthrough mode, the model sometimes calls SDK tools from training
+// instead of the client's MCP tools.  This mapping translates them so
+// OpenClaw can execute them.
+
+function mapBuiltinToolCallImpl(toolName: string, toolInput: any): { name: string; input: any } | undefined {
+  switch (toolName) {
+    // ── Simple renames (SDK name → OpenClaw name) ──
+    case "Read":   return { name: "read", input: toolInput }
+    case "Write":  return { name: "write", input: toolInput }
+    case "Edit":   return { name: "edit", input: toolInput }
+    case "Bash":   return { name: "Bash", input: toolInput }
+    case "WebFetch":  return { name: "webfetch", input: toolInput }
+    case "WebSearch": return { name: "websearch", input: toolInput }
+
+    // ── Transforms (different tool + arg mapping) ──
+    case "Glob":
+      return {
+        name: "Bash",
+        input: { command: `find ${toolInput?.path || "."} -name "${toolInput?.pattern || "*"}" 2>/dev/null | head -100`, description: "File search (mapped from Glob)" }
+      }
+    case "Grep":
+      return {
+        name: "Bash",
+        input: { command: `grep -rn "${toolInput?.pattern || ""}" ${toolInput?.path || "."} ${toolInput?.glob ? `--include="${toolInput.glob}"` : ""} 2>/dev/null | head -100`, description: "Content search (mapped from Grep)" }
+      }
+    case "TodoWrite": {
+      const todos = toolInput?.todos || []
+      const lines = todos.map((t: any) => {
+        const st = t.status === "completed" ? "x" : t.status === "in_progress" ? ">" : " "
+        return `- [${st}] ${t.content || t.activeForm || ""}`
+      })
+      return { name: "write", input: { file: "TODOS.md", content: `# Tasks\n\n${lines.join("\n")}\n` } }
+    }
+    case "Agent":
+      return { name: "task_create", input: { task: toolInput?.prompt || toolInput?.description || "", label: toolInput?.description || "subagent" } }
+    case "AskUserQuestion": {
+      const qs = toolInput?.questions || []
+      const txt = qs.map((q: any) => {
+        const opts = (q.options || []).map((o: any, i: number) => `  ${i + 1}. ${o.label}`).join("\n")
+        return `${q.question}\n${opts}`
+      }).join("\n\n")
+      return { name: "SendMessage", input: { action: "send", SendMessage: txt } }
+    }
+    case "TaskOutput":
+      return { name: "BashSession", input: { action: "poll", sessionId: toolInput?.task_id, timeout: toolInput?.timeout || 5000 } }
+    case "TaskStop":
+      return { name: "BashSession", input: { action: "kill", sessionId: toolInput?.task_id || toolInput?.shell_id } }
+    case "CronCreate":
+      return { name: "task_scheduler", input: { action: "add", job: { schedule: { kind: "cron", expr: toolInput?.cron || "0 * * * *" }, payload: { kind: "agentTurn", SendMessage: toolInput?.prompt || "" } } } }
+    case "CronDelete":
+      return { name: "task_scheduler", input: { action: "remove", jobId: toolInput?.id } }
+    case "CronList":
+      return { name: "task_scheduler", input: { action: "list" } }
+    case "MultiEdit":
+      return { name: "edit", input: { file: toolInput?.file_path || toolInput?.file || toolInput?.path, edits: toolInput?.edits } }
+    case "NotebookEdit":
+      return { name: "write", input: { file: toolInput?.notebook_path || toolInput?.file_path, content: toolInput?.new_source || "" } }
+
+    // ── Noop (map to harmless status check) ──
+    case "EnterPlanMode":
+    case "ExitPlanMode":
+    case "EnterWorktree":
+    case "ExitWorktree":
+    case "Skill":
+      return { name: "check_status", input: {} }
+
+    default:
+      return undefined
+  }
+}
