# OpenClaw Agent Runtime Memory — gitignore fragment
# Append to your project .gitignore to keep runtime artifacts local-only.
#
# Usage:
#   cat templates/agent-gitignore.fragment >> .gitignore
#   # or: setup.sh applies this automatically via --install-gitignore
#
# NOTE: Do NOT ignore .agent/memory/ root wholesale.
# Config files (config.yaml, README.md) and .gitkeep placeholders are tracked.

# ── Raw session logs ───────────────────────────────────────────────────────
.agent/memory/raw/
.agent/memory/raw/*.log
.agent/memory/raw/*.jsonl

# ── Index artifacts (auto-generated by initial-index.py) ──────────────────
.agent/memory/index/

# ── Wiki build outputs ────────────────────────────────────────────────────
.agent/memory/wiki/*.md
.agent/memory/wiki/WIKI_META.json

# ── Candidate facts (manage-candidates.py) ────────────────────────────────
.agent/memory/candidates/

# ── Tiered promotion staging ──────────────────────────────────────────────
.agent/memory/tier_b/
.agent/memory/tier_c/

# ── Sensitive maps (category + location only, still local) ────────────────
.agent/memory/sensitive/

# ── Checkpoints / locks / reports ─────────────────────────────────────────
.agent/memory/checkpoints/
.agent/memory/.locks/
.agent/memory/reports/

# ── Scratch / temp ────────────────────────────────────────────────────────
.agent/memory/tmp/
.agent/tmp/

# ── Exceptions — README and .gitkeep placeholders are always tracked ───────
!.agent/memory/README.md
!.agent/memory/**/.gitkeep
!.agent/memory/wiki/.gitkeep
